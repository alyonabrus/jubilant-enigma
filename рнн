    vocab_size_estimated = len(set(text_data))
    print(f"Оценка размера словаря: {vocab_size_estimated} символов")
    
    rnn_model = SimpleRNN(
        vocab_size=vocab_size_estimated,
        hidden_size=64,
        num_layers=3,
        learning_rate=0.005
    )
    
    print("Начало обучения...")
    char_to_idx_map, idx_to_char_map = rnn_model.train(text_data[:50000], epochs=300)
    
    print("\nГенерация текста:")
    generated_text_sample = rnn_model.generate(
        start_char=text_data[0],
        idx_to_char=idx_to_char_map,
        length=200
    )
    print(generated_text_sample)
